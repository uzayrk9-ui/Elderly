  <header>
    <div class="logo"><a href="/"><h1>Elder Ease<sup>&reg;</sup></h1></a></div>
    <form action="/search" method="GET" class="search-form" role="search" autocomplete="off">
      <div class="search-box">
        <input type="search" id="search-input" name="q" placeholder="Search products..."
               aria-label="Search products" aria-autocomplete="list" aria-controls="search-suggestions"
               value="<%= typeof q !== 'undefined' ? q : '' %>" />
        <ul id="search-suggestions" class="search-suggestions" role="listbox" hidden></ul>
      </div>
      <button type="submit">Search</button>
    </form>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/shop">Shop</a></li>
        <li><a href="/cart">Cart<% if (cartCount > 0) { %> <span class="cart-count"><%= cartCount %></span><% } %></a></li>
        <% if (user) { %>
          <li><a href="/wishlist">Wishlist<% if (wishlistCount > 0) { %> <span class="cart-count"><%= wishlistCount %></span><% } %></a></li>
          <li><a href="/account">My Account</a></li>
          <% if (user.is_admin) { %><li><a href="/admin">Admin</a></li><% } %>
          <li><a href="/support">Support</a></li>
          <li>
            <form action="/logout" method="POST" class="inline-form">
              <%- include('csrf') %>
              <a href="#" onclick="this.closest('form').submit(); return false;">Log Out</a>
            </form>
          </li>
        <% } else { %>
          <li><a href="/support">Support</a></li>
          <li><a href="/login">Log In</a></li>
        <% } %>
      </ul>
    </nav>
  </header>
  <% if (flash) { %>
    <div class="flash flash-<%= flash.type %>"><%= flash.msg %></div>
  <% } %>
