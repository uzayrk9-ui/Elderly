<%- include('partials/head', { title, css: 'editprofile.css' }) %>
<%- include('partials/header') %>

  <main>
    <section class="edit-profile-title">
      <h1>Log In</h1>
      <p>Welcome back to Elder Ease.</p>
    </section>

    <form class="auth-form" action="/login" method="POST">
      <%- include('partials/csrf') %>
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" value="margaret@example.com" required />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" value="password123" required />
      </div>
      <button type="submit" class="submit-btn">Log In</button>
    </form>
    <p class="auth-switch">No account yet? <a href="/register">Create one</a></p>
  </main>

<%- include('partials/footer') %>
