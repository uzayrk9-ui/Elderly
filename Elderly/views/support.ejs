<%- include('partials/head', { title, css: 'support.css' }) %>
<%- include('partials/header') %>

  <main>
    <section class="support-title">
      <h1>Support &amp; Help</h1>
      <p>We're here to help. Read our return policy or contact us directly below.</p>
    </section>

    <section id="return-policy">
      <h2>Return Policy</h2>
      <p>If you are not fully satisfied with your purchase, you may return it within 30 days for a full refund.</p>
      <ul>
        <li>Items must be unused and in their original packaging.</li>
        <li>Return shipping is free for orders over $50.</li>
        <li>Refunds are processed within 5–7 business days.</li>
        <li>Call us anytime for help arranging a return.</li>
      </ul>
    </section>

    <section id="contact-us">
      <h2>Contact Us</h2>
      <p>Send us a message and our friendly team will get back to you soon.</p>
      <form action="/support/contact" method="POST">
        <%- include('partials/csrf') %>
        <div class="form-group">
          <label for="contact-name">Your Name</label>
          <input type="text" id="contact-name" name="name" required />
        </div>
        <div class="form-group">
          <label for="contact-email">Your Email</label>
          <input type="email" id="contact-email" name="email" required />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="submit-btn">Send Message</button>
      </form>
    </section>
  </main>

<%- include('partials/footer') %>
