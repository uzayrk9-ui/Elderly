<%- include('partials/head', { title, css: 'admin.css' }) %>
<%- include('partials/header') %>

  <main>
    <section class="admin-header">
      <h1>Products</h1>
      <a href="/admin/products/new" class="btn-primary">+ Add Product</a>
    </section>
    <%- include('partials/admin-nav', { adminTab: 'products' }) %>

    <table class="admin-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Stock</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(p) { %>
          <tr>
            <td>
              <img class="admin-thumb" src="<%= p.image ? p.image : placeholder(p.name, 80, 60) %>"
                   alt="<%= p.name %>" loading="lazy"
                   onerror="this.onerror=null;this.src='<%= placeholder(p.name, 80, 60) %>'" />
            </td>
            <td>
              <a href="/product/<%= p.id %>"><%= p.name %></a><br>
              <small class="muted"><%= p.department %></small>
            </td>
            <td><span class="cat-badge"><%= p.category %></span></td>
            <td><%= money(p.price) %></td>
            <td>
              <span class="stock-pill <%= p.stock <= 0 ? 'out' : (p.stock <= 5 ? 'low' : 'in') %>"><%= p.stock %></span>
            </td>
            <td class="admin-actions">
              <a href="/admin/products/<%= p.id %>/edit" class="btn-small">Edit</a>
              <form action="/admin/products/<%= p.id %>/delete" method="POST" class="inline-form"
                    onsubmit="return confirm('Delete “<%= p.name %>”?');">
                <%- include('partials/csrf') %>
                <button type="submit" class="btn-small btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>

<%- include('partials/footer') %>
